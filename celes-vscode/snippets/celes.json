{
  "Celes Declaration": {
    "prefix": "celes",
    "body": ["<!Celes-0.1.4>"],
    "description": "Celes version declaration"
  },
  "Title": {
    "prefix": "title",
    "body": ["<title>{$1}"],
    "description": "Document tab title"
  },
  "Author": {
    "prefix": "author",
    "body": ["<author>{$1}"],
    "description": "Document author metadata"
  },
  "Date": {
    "prefix": "date",
    "body": ["<date>{${1:dd/mm/yyyy}}"],
    "description": "Document date metadata"
  },
  "Section": {
    "prefix": "section",
    "body": ["<section>{$1}"],
    "description": "Named section divider"
  },
  "Header": {
    "prefix": "header",
    "body": ["<header -size=${1|1,2,3,4,5,6|}>{$2}"],
    "description": "Heading h1–h6"
  },
  "Line": {
    "prefix": "line",
    "body": ["<line>{$1}"],
    "description": "Paragraph line"
  },
  "Line Centered": {
    "prefix": "linec",
    "body": ["<line -align=center>{$1}"],
    "description": "Centered paragraph line"
  },
  "Line Right": {
    "prefix": "liner",
    "body": ["<line -align=right>{$1}"],
    "description": "Right-aligned paragraph line"
  },
  "Bold": {
    "prefix": "bold",
    "body": ["<bold>{$1}"],
    "description": "Bold inline text"
  },
  "Italic": {
    "prefix": "italic",
    "body": ["<italic>{$1}"],
    "description": "Italic inline text"
  },
  "Bold Italic": {
    "prefix": "bolditalic",
    "body": ["<bold+italic>{$1}"],
    "description": "Bold and italic inline text"
  },
  "Underline": {
    "prefix": "underline",
    "body": ["<underline>{$1}"],
    "description": "Underlined inline text"
  },
  "Strikethrough": {
    "prefix": "strike",
    "body": ["<strike>{$1}"],
    "description": "Strikethrough inline text"
  },
  "Superscript": {
    "prefix": "super",
    "body": ["<super>{$1}"],
    "description": "Superscript inline text"
  },
  "Subscript": {
    "prefix": "sub",
    "body": ["<sub>{$1}"],
    "description": "Subscript inline text"
  },
  "Highlight": {
    "prefix": "mark",
    "body": ["<mark>{$1}"],
    "description": "Highlighted / marked text"
  },
  "Inline Code": {
    "prefix": "code",
    "body": ["<code>{$1}"],
    "description": "Inline code"
  },
  "Code Block": {
    "prefix": "codeblock",
    "body": ["<codeblock>{$1}"],
    "description": "Multi-line code block"
  },
  "Link": {
    "prefix": "link",
    "body": ["<link -body=${1:display text}>{${2:url}}"],
    "description": "Hyperlink"
  },
  "Button": {
    "prefix": "button",
    "body": ["<button -body=${1:label}>{${2:url}}"],
    "description": "Clickable button link"
  },
  "Image": {
    "prefix": "image",
    "body": ["<image>{${1:path/or/url}}"],
    "description": "Image"
  },
  "Linked Image": {
    "prefix": "linkimage",
    "body": ["<linkimage -image=${1:path.png}>{${2:url}}"],
    "description": "Clickable image"
  },
  "Bullet List Item": {
    "prefix": "list",
    "body": ["<list -bullet=circle>{$1}"],
    "description": "Bullet list item"
  },
  "Numbered List Item": {
    "prefix": "listn",
    "body": ["<list -bullet=number>{$1}"],
    "description": "Numbered list item"
  },
  "Sublist Item": {
    "prefix": "sublist",
    "body": ["<sublist -bullet=circle>{$1}"],
    "description": "Nested bullet sublist item"
  },
  "Subsublist Item": {
    "prefix": "subsublist",
    "body": ["<subsublist -bullet=circle>{$1}"],
    "description": "Third-level nested list item"
  },
  "Table": {
    "prefix": "table",
    "body": [
      "<table>{${1:Col1}, ${2:Col2}, ${3:Col3}}",
      "<item>{${4:val1}, ${5:val2}, ${6:val3}}"
    ],
    "description": "Table with header and one row"
  },
  "Table Item": {
    "prefix": "item",
    "body": ["<item>{$1}"],
    "description": "Table row"
  },
  "Blockquote": {
    "prefix": "blockquote",
    "body": ["<blockquote>{$1}"],
    "description": "Blockquote"
  },
  "Nested Quote": {
    "prefix": "nestquote",
    "body": ["<nestquote>{$1}"],
    "description": "Nested blockquote inside a blockquote"
  },
  "Checkmark Checked": {
    "prefix": "check",
    "body": ["<checkmark -check>{$1}"],
    "description": "Checked task item"
  },
  "Checkmark Unchecked": {
    "prefix": "uncheck",
    "body": ["<checkmark -uncheck>{$1}"],
    "description": "Unchecked task item"
  },
  "Empty (Raw Text)": {
    "prefix": "empty",
    "body": ["<empty>{$1}"],
    "description": "Raw text block — nothing inside is parsed"
  },
  "Newline": {
    "prefix": "newline",
    "body": ["<newline>"],
    "description": "Line break"
  },
  "Page Break": {
    "prefix": "pagebreak",
    "body": ["<pagebreak>"],
    "description": "Page break"
  },
  "Insert Space": {
    "prefix": "insertspace",
    "body": ["<insertspace>"],
    "description": "Extra spacing / horizontal rule"
  },
  "Comment": {
    "prefix": "comment",
    "body": ["; $1"],
    "description": "Comment line"
  },
  "Full Document": {
    "prefix": "celes-doc",
    "body": [
      "<!Celes-0.1.4>",
      "<title>{${1:Document Title}}",
      "<author>{${2:Author Name}}",
      "<date>{${3:dd/mm/yyyy}}",
      "<header -size=1>{${1:Document Title}}",
      "<line>{$4}"
    ],
    "description": "Starter Celes 0.1.4 document"
  }
}
